# Deep Research - Environment Variables Template
# Copy this file to .env and add your actual API keys
# DO NOT commit .env to git - it's in .gitignore

# OpenAI API Key (required for GPT models)
OPENAI_API_KEY=your_openai_key_here

# Anthropic API Key (required for Claude models)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Qwen API Key (optional, for Qwen search method)
QWEN_API_KEY=your_qwen_key_here

# Tavily API Key (optional, for Tavily search)
TAVILY_API_KEY=your_tavily_key_here

# DeepSeek API Key (optional, for DeepSeek models)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Model Configuration (optional)
PLANNER_MODEL=gpt-4o-mini
EXECUTOR_MODEL=gpt-4o-mini
SYNTHESIZER_MODEL=gpt-4o-mini
FACT_CHECKER_MODEL=gpt-4o-mini
